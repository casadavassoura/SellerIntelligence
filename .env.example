# Copiar para .env e preencher — nunca commitar .env real (docs/12-security.md §3)

DATABASE_URL=postgresql+asyncpg://seller_intelligence_app:app_local_dev_only@pgbouncer:5432/seller_intelligence
REDIS_BROKER_URL=redis://redis-broker:6379/0
REDIS_CACHE_URL=redis://redis-cache:6379/0

JWT_SECRET_KEY=change-me-local-dev-only
JWT_ACCESS_TOKEN_TTL_MINUTES=15
JWT_REFRESH_TOKEN_TTL_DAYS=14

MFA_ISSUER_NAME=SellerIntelligence

# Gerar com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=change-me-generate-a-real-fernet-key-see-comment-above

# Rate limiter da integração Shopee (docs/03-architecture.md §11). O bucket por tenant é
# o limite real documentado pela Shopee (~10 req/s por loja); o global é margem de
# engenharia própria, não um número oficial da Shopee.
SHOPEE_TENANT_RATE_LIMIT_PER_SECOND=10.0
SHOPEE_GLOBAL_RATE_LIMIT_PER_SECOND=50.0

# App parceiro Shopee (Open Platform) — mesmo app para todos os tenants. Sandbox por
# padrão; nunca aponte para a API de produção sem validar antes no test-stable.
SHOPEE_PARTNER_ID=change-me-shopee-partner-id
SHOPEE_PARTNER_KEY=change-me-shopee-partner-key
SHOPEE_REDIRECT_URI=http://localhost:8000/api/v1/integrations/shopee/callback
SHOPEE_API_BASE_URL=https://partner.test-stable.shopeemobile.com
