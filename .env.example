# Copiar para .env e preencher — nunca commitar .env real (docs/12-security.md §3)

DATABASE_URL=postgresql+asyncpg://seller_intelligence_app:app_local_dev_only@pgbouncer:5432/seller_intelligence
REDIS_BROKER_URL=redis://redis-broker:6379/0
REDIS_CACHE_URL=redis://redis-cache:6379/0

JWT_SECRET_KEY=change-me-local-dev-only
JWT_ACCESS_TOKEN_TTL_MINUTES=15
JWT_REFRESH_TOKEN_TTL_DAYS=14

MFA_ISSUER_NAME=SellerIntelligence

# Gerar com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=change-me-generate-a-real-fernet-key-see-comment-above
